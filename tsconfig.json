{
  "files": ["lib/index.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es6", "dom", "es2017", "es2019", "es2022"],
    "strict": true,
    "module": "commonjs",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    // "sourceMap": true,

    /* OMG. webpack ts-loader bypased due to this */
    "rootDir": "./lib",
    "noImplicitAny": false,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,
    "jsx": "react",
    "noUncheckedIndexedAccess": true
  },
  "include": ["lib"],
  "exclude": ["./dist", "./tests", "node_modules"]
}
